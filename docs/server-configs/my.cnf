# =============================================================================
# MySQL 8.x Configuration — CBT SMK LMS
# Server: Intel Xeon 20-core, 16GB RAM, HDD
# Target: 500 concurrent students, 3 sessions/day
# Path: /etc/mysql/mysql.conf.d/mysqld.cnf
# =============================================================================

[mysqld]

# === InnoDB Buffer Pool ===
# 8.5GB available for MySQL. Buffer pool = ~70% of MySQL allocation.
# HDD makes buffer pool CRITICAL — all hot data must fit in RAM.
innodb_buffer_pool_size         = 6G
innodb_buffer_pool_instances    = 4

# === InnoDB Log ===
# Larger log = fewer disk flushes on HDD. 512MB per file × 2 = 1GB redo log.
innodb_log_file_size            = 512M
innodb_log_buffer_size          = 64M

# === Flush Strategy (CRITICAL for HDD) ===
# Value 2: flush to OS buffer per commit, disk write every 1 second.
# Trade-off: max 1 second data loss on crash (acceptable — Redis is backup).
innodb_flush_log_at_trx_commit  = 2

# O_DIRECT: bypass OS file cache (InnoDB has its own buffer pool).
# Prevents double-caching that wastes RAM.
innodb_flush_method             = O_DIRECT

# === Write Performance (HDD) ===
# Aggressive I/O merge for HDD sequential writes.
innodb_io_capacity              = 200
innodb_io_capacity_max          = 400
innodb_write_io_threads         = 8
innodb_read_io_threads          = 8

# === Connections ===
# PHP-FPM max_children (90) + queue workers (5) + cron + admin + buffer
max_connections                 = 150
wait_timeout                    = 60
interactive_timeout             = 120

# === Temp Tables (HDD sensitive) ===
# Temp tables exceeding this write to disk — very slow on HDD.
tmp_table_size                  = 128M
max_heap_table_size             = 128M

# === Join/Sort Buffers ===
# Per-connection allocation — don't set too high.
join_buffer_size                = 4M
sort_buffer_size                = 4M
read_rnd_buffer_size            = 2M

# === Table Open Cache ===
table_open_cache                = 4000
table_definition_cache          = 2000

# === Binary Log (disable if no replication) ===
skip-log-bin

# === Slow Query Log ===
slow_query_log                  = 1
slow_query_log_file             = /var/log/mysql/slow.log
long_query_time                 = 1
log_queries_not_using_indexes   = 1
